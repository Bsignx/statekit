{
  "name": "statekit",
  "version": "0.1.0",
  "description": "Lightweight vanilla JS reactivity library inspired by React hooks with pub/sub events",
  "type": "module",
  "main": "dist/statekit.cjs.js",
  "module": "dist/statekit.esm.js",
  "browser": "dist/statekit.umd.js",
  "exports": {
    ".": {
      "import": "./dist/statekit.esm.js",
      "require": "./dist/statekit.cjs.js",
      "default": "./dist/statekit.esm.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "demo": "npx serve . -l 3000"
  },
  "keywords": [
    "reactive",
    "vanilla-js",
    "hooks",
    "state-management",
    "pub-sub",
    "event-bus",
    "signals",
    "lightweight"
  ],
  "author": "Bruno Mariano",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.0",
    "eslint": "^9.0.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.0.0",
    "rollup": "^4.0.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
