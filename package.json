{
  "name": "@bsignx/statekit",
  "version": "0.1.0",
  "description": "Lightweight TypeScript reactivity library inspired by React hooks with pub/sub events",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "demo": "npx serve . -l 3000"
  },
  "keywords": [
    "reactive",
    "vanilla-js",
    "hooks",
    "state-management",
    "pub-sub",
    "event-bus",
    "signals",
    "lightweight"
  ],
  "author": "Bruno Mariano",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^2.0.0"
  }
}
